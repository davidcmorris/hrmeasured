<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ description or site.description }}" />
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=DM+Serif+Display&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="icon" type="image/svg+xml" href="/img/logo_hr_measured.svg" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-logo">
        <span class="logo-mark">HR</span><span class="logo-text">Measured</span>
      </a>
      <nav class="site-nav">
        {% for item in site.nav %}
          <a href="{{ item.url }}" class="nav-link{% if page.url == item.url %} active{% endif %}">{{ item.label }}</a>
        {% endfor %}
      </nav>
      <button class="nav-toggle" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href="/" class="site-logo">
            <span class="logo-mark">HR</span><span class="logo-text">Measured</span>
          </a>
          <p>Rigorous analytics for people decisions.</p>
        </div>
        <nav class="footer-nav">
          {% for item in site.nav %}
            <a href="{{ item.url }}">{{ item.label }}</a>
          {% endfor %}
        </nav>
      </div>
      <div class="footer-bottom">
        <p>&copy; {{ site.title }} {{ site.year }}. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.querySelector('.nav-toggle');
    const nav = document.querySelector('.site-nav');
    toggle.addEventListener('click', () => nav.classList.toggle('open'));
  </script>
</body>
</html>
