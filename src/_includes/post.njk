---
layout: base.njk
---
<article class="post-article">
  <div class="container container--narrow">
    <header class="post-header">
      <div class="post-meta">
        <time>{{ date | readableDate }}</time>
        {% if tags %}
          {% for tag in tags %}
            {% if tag != "posts" %}
              <span class="tag">{{ tag }}</span>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
      <h1>{{ title }}</h1>
      {% if excerpt %}<p class="post-excerpt">{{ excerpt }}</p>{% endif %}
    </header>
    <div class="post-body">
      {{ content | safe }}
    </div>
    <footer class="post-footer">
      <a href="/insights/" class="back-link">&larr; All Insights</a>
    </footer>
  </div>
</article>
